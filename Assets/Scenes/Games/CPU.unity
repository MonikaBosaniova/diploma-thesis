    - target: {fileID: 5427176538588272188, guid: 8e18345512c32f9449221b68bdfd17dd, type: 3}
      propertyPath: m_text
      value: "Aby tohle v\u0161echno st\xEDhal, pracuje v rytmu takzvan\xFDch <color=green><b>takt\u016F</color></b>
        \u2013 je to jako metronom nebo tep. \n\n<color=green><b>Taktovac\xED frekvence</color></b>
        \u0159\xEDk\xE1, kolik krok\u016F CPU zvl\xE1dne za <color=green><b>jednu
        sekundu</color></b>. \n\n\u010C\xEDm je vy\u0161\u0161\xED, t\xEDm rychleji
        kmit\xE1, ale pamatuj \u2013 celkov\xE1 <color=green><b>rychlost po\u010D\xEDta\u010De</color></b>
        z\xE1vis\xED i na dal\u0161\xEDch v\u011Bcech!"
      objectReference: {fileID: 0}
    - target: {fileID: 6803601083831967028, guid: 8e18345512c32f9449221b68bdfd17dd, type: 3}
      propertyPath: m_LocalPosition.x
