    - target: {fileID: 5427176538588272188, guid: 8e18345512c32f9449221b68bdfd17dd, type: 3}
      propertyPath: m_text
      value: "Bude se sna\u017Eit zachr\xE1nit t\xEDm, \u017Ee <color=green><b>zpomal\xED</color></b>,
        aby se tolik neh\u0159\xE1l. Pokud to nesta\u010D\xED, po\u010D\xEDta\u010D
        se m\u016F\u017Ee <color=green><b>zaseknout</color></b>, restartovat nebo
        \xFApln\u011B <color=green><b>vypnout</color></b>, aby se procesor nepo\u0161kodil.
        Proto m\xEDvaj\xED po\u010D\xEDta\u010De <color=green><b>chlazen\xED</color></b>,
        nap\u0159\xEDklad kovov\xFD chladi\u010D a <color=green><b>v\u011Btr\xE1k</color></b>."
      objectReference: {fileID: 0}
