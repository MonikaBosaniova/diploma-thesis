    - target: {fileID: 5427176538588272188, guid: 8e18345512c32f9449221b68bdfd17dd, type: 3}
      propertyPath: m_text
      value: "Kdy\u017E <color=green><b>CPU</color></b> hodn\u011B pracuje, za\u010Dne
        se zah\u0159\xEDvat. Pokud je z\xE1t\u011B\u017E p\u0159\xEDli\u0161 vysok\xE1
        bez <color=green><b>chlazen\xED</color></b> nest\xEDh\xE1, teplota m\u016F\u017Ee
        vystoupat na nebezpe\u010Dnou \xFArove\u0148. Co se stane pak?"
      objectReference: {fileID: 0}
