    - target: {fileID: 5427176538588272188, guid: 8e18345512c32f9449221b68bdfd17dd, type: 3}
      propertyPath: m_text
      value: "Kdy\u017E spust\xED\u0161 hru nebo otev\u0159e\u0161 web, <color=green><b>CPU</color></b>
        neust\xE1le dokola zpracov\xE1v\xE1 p\u0159\xEDkazy typu: <color=green><b>\u201Ena\u010Dti
        data\u201C</color></b>, <color=green><b>\u201Espo\u010D\xEDtej tohle\u201C</color></b>
        nebo <color=green><b>\u201Epo\u0161li v\xFDsledek d\xE1l\u201C</color></b>.
        Jsou to miliony mal\xFDch krok\u016F, kter\xE9 tvo\u0159\xED v\u0161e, co
        vid\xED\u0161 na obrazovce!"
      objectReference: {fileID: 0}
